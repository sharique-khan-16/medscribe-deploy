# MedScribe Environment Configuration Example
# Copy this file to .env and configure the variables as needed

# Host and Port configuration for FastAPI backend
HOST=0.0.0.0
PORT=8000

# OCR Engine Configurations (Optional local path override)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Local Ollama Host configuration (Default is localhost:11434)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# SQLite Database Filename
DB_PATH=data/medscribe.db
